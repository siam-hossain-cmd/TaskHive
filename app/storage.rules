rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Size check helper (max 50MB) 
    function isValidSize() {
      return request.resource == null || request.resource.size <= 50 * 1024 * 1024;
    }

    // Allow authenticated users to upload to ai_analysis folder
    // Any authenticated user can read (team members need to view PDFs)
    match /ai_analysis/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId && isValidSize();
    }

    // Allow authenticated users to read/write their own files
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId && isValidSize();
    }

    // Chat images - authenticated users can read/write
    match /chat_images/{chatId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isValidSize();
    }

    // Chat files - authenticated users can read/write
    match /chat_files/{chatId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isValidSize();
    }

    // Task attachments - any authenticated user can read/write
    match /tasks/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isValidSize();
    }

    // Submissions
    match /submissions/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isValidSize();
    }

    // Profile images
    match /profile_images/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId && isValidSize();
    }
  }
}
